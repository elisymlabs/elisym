{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "dictionaryDefinitions": [
    {
      "name": "elisym-dictionary",
      "path": "./cspell-dictionary.txt",
      "addWords": true
    }
  ],
  "dictionaries": ["elisym-dictionary", "node", "npm", "softwareTerms", "typescript"],
  "ignorePaths": [
    "/.git",
    "/dist",
    "/build",
    "/node_modules",
    "/bun.lock",
    "/.turbo",
    "**/*.json",
    "**/*.css",
    "**/skills-examples/**",
    "**/landing/src/components/**"
  ],
  "language": "en",
  "version": "0.2"
}
