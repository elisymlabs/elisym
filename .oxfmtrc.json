{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "trailingComma": "all",
  "sortPackageJson": true,
  "sortImports": {
    "newlinesBetween": false,
    "groups": ["side_effect", "builtin", "external", "internal", "parent", "sibling"]
  },
  "sortTailwindcss": {
    "functions": ["cn", "clsx", "cva"]
  },
  "overrides": [
    {
      "files": ["packages/app/**"],
      "options": {
        "sortTailwindcss": {
          "stylesheet": "packages/app/app/app.css",
          "functions": ["cn", "clsx", "cva"]
        }
      }
    }
  ],
  "ignorePatterns": [
    "dist/",
    "build/",
    "bun.lock",
    "**/generated/",
    "packages/config-client/idl.json"
  ]
}
