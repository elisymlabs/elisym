{
  "name": "@elisym/sdk",
  "version": "0.8.0",
  "description": "TypeScript SDK for elisym - AI agent discovery, marketplace, and payments on Nostr",
  "keywords": [
    "ai-agents",
    "discovery",
    "marketplace",
    "nip-89",
    "nip-90",
    "nostr",
    "payments",
    "solana",
    "typescript"
  ],
  "homepage": "https://github.com/elisymlabs/elisym",
  "bugs": {
    "url": "https://github.com/elisymlabs/elisym/issues"
  },
  "license": "MIT",
  "author": "elisym labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/elisymlabs/elisym.git",
    "directory": "packages/sdk"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./node": {
      "import": {
        "types": "./dist/node.d.ts",
        "default": "./dist/node.js"
      },
      "require": {
        "types": "./dist/node.d.cts",
        "default": "./dist/node.cjs"
      }
    },
    "./agent-store": {
      "import": {
        "types": "./dist/agent-store.d.ts",
        "default": "./dist/agent-store.js"
      },
      "require": {
        "types": "./dist/agent-store.d.cts",
        "default": "./dist/agent-store.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      }
    },
    "./skills": {
      "import": {
        "types": "./dist/skills.d.ts",
        "default": "./dist/skills.js"
      },
      "require": {
        "types": "./dist/skills.d.cts",
        "default": "./dist/skills.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "format:check": "oxfmt --check src/ tests/",
    "qa": "tsup && vitest run && tsc --noEmit && oxlint src/ && oxfmt --check src/ tests/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "yaml": "~2.8.3",
    "zod": "~3.25.0"
  },
  "devDependencies": {
    "@elisym/config-client": "workspace:*",
    "@solana-program/system": "~0.12.0",
    "@solana/kit": "~6.8.0",
    "@types/node": "~25.5.0",
    "decimal.js-light": "~2.5.1",
    "nostr-tools": "~2.23.0",
    "tsup": "~8.4.0",
    "typescript": "~5.7.0",
    "vitest": "~3.0.0"
  },
  "peerDependencies": {
    "@solana-program/system": "~0.12.0",
    "@solana/kit": "~6.8.0",
    "decimal.js-light": "~2.5.0",
    "nostr-tools": "~2.23.0"
  },
  "engines": {
    "node": ">=20"
  }
}
