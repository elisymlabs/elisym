{
  "name": "elisym",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint packages/sdk/src/ packages/mcp/src/ packages/cli/src/ packages/app/app/",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "spell": "cspell --no-progress \"packages/sdk/src/**\" \"packages/mcp/src/**\" \"packages/cli/src/**\" \"packages/app/app/**\" \"*.md\" \"packages/*/README.md\"",
    "qa": "turbo run build && turbo run test && turbo run typecheck && bun run lint && oxfmt --check . && bun run spell",
    "clean": "turbo run clean",
    "program:build": "anchor build",
    "program:test": "cargo test --package elisym-config --test config -- --test-threads=1",
    "program:test:ts": "vitest run --config programs/elisym-config/vitest.config.ts",
    "program:deploy:devnet": "anchor deploy --provider.cluster devnet",
    "program:idl:generate": "anchor build && cp target/idl/elisym_config.json packages/config-client/idl.json"
  },
  "devDependencies": {
    "cspell": "~9.0.0",
    "oxfmt": "~0.42.0",
    "oxlint": "~0.16.0",
    "turbo": "~2.4.0",
    "typescript": "~5.7.0"
  },
  "packageManager": "bun@1.3.11"
}
